---
import globalConfig from "../content/config/config.json";
import contactConfig from "../content/contact/config.json";
import IconLink from "./react/IconLink";
const today = new Date();
import styles from './Footer.module.css';
---

<footer class={styles.copyrightFooter}>
    &copy; {today.getFullYear()}
    {globalConfig.seo.siteOwner}. All rights reserved.
    <div class={styles.socialLinks}>
        {
            contactConfig?.contact?.map((link) => {
                return (
                        <IconLink {...link} />
                );
            })
        }
    </div>
</footer>

