---
// SideBar.astro
import SideBarMenu from './SideBarMenu.astro';
import SideBarFooter from './react/SideBarFooter';
import styles from './SideBar.module.css';
import Person from './Person.astro'
---

<input type="checkbox" id="sidebar-toggle" class={styles.sidebarToggle}/>
<label for="sidebar-toggle" class={styles.overlay}></label>
<div class={styles.drawerSide}>
    <aside class={styles.sidebar}>
        <label for="sidebar-toggle" class={styles.toggleButton}>
            <span class={styles.hamburger}></span>
        </label>

        <Person/>
        <SideBarMenu/>
        <SideBarFooter/>
    </aside>
</div>

